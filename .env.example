SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
DATABASE_URL=
# Generate with: openssl rand -hex 32
NUXT_AUTH_ENCRYPTION_KEY=
# Redis connection string (e.g. Upstash: rediss://...)
REDIS_URL=
# Google OAuth — from Google Cloud Console → APIs & Services → Credentials
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=
# Brevo — from app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=
# Must be a verified sender on Brevo (Settings → Senders & IP → Senders)
BREVO_FROM_EMAIL=
# Public app URL used in email links (no trailing slash)
APP_URL=http://localhost:3000
