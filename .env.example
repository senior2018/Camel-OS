# ─────────────────────────────────────────────────────────────────────────────
# Camel OS — environment variables
# Copy to `.env` and fill in. Every value below is REQUIRED unless marked optional.
# Generate your own secrets — do not reuse another environment's keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase) ──────────────────────────────────────────────────────
# Supabase dashboard → Settings → Database → Connection string.
# Use the TRANSACTION POOLER (port 6543), URL-encode special chars in the password.
DATABASE_URL=

# Supabase dashboard → Settings → API
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Service-role key (server-side only) — needed for Storage (attachments). Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth / sessions ──────────────────────────────────────────────────────────
# Session cookie secret (min 32 chars). Generate: openssl rand -base64 32
NUXT_SESSION_PASSWORD=
# Encryption key for MFA secrets at rest. Generate: openssl rand -hex 32
NUXT_AUTH_ENCRYPTION_KEY=

# ── Cache / rate limiting (Redis, e.g. Upstash) ──────────────────────────────
REDIS_URL=

# ── Email (Brevo) ────────────────────────────────────────────────────────────
# app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=
# A VERIFIED sender (Brevo → Settings → Senders & IP → Senders)
BREVO_FROM_EMAIL=

# ── App ──────────────────────────────────────────────────────────────────────
# Public URL used in email links (no trailing slash). e.g. https://camel-os.vercel.app
APP_URL=http://localhost:3000

# ── Scheduled jobs on serverless hosts (Vercel) ──────────────────────────────
# Secret that protects /api/cron/* so only the platform scheduler can run them.
# Set this in Vercel too — Vercel sends it automatically as a Bearer token.
# Generate: openssl rand -hex 32   (omit on always-on hosts that use the built-in task runner)
CRON_SECRET=

# ── Google OAuth (OPTIONAL — only if Google sign-in is enabled) ──────────────
# Google Cloud Console → APIs & Services → Credentials
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=
